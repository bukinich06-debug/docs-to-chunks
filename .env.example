# LLM backend: "ollama" (default) or "vllm"
# LLM_BACKEND=ollama

# --- Ollama (used when LLM_BACKEND=ollama) ---
# Optional: Ollama base URL (default: http://localhost:11434)
# OLLAMA_URL=http://localhost:11434

# Optional: Ollama model with 8k context (default: llama3.2)
# OLLAMA_MODEL=llama3.2

# --- vLLM (used when LLM_BACKEND=vllm) ---
# vLLM server URL (e.g. OpenAI-compatible server)
# VLLM_URL=http://localhost:8000

# Model name as deployed on vLLM
# VLLM_MODEL=meta-llama/Llama-3.2-3B-Instruct

# Optional: max_tokens for vLLM chat completions (default: 4096)
# VLLM_MAX_TOKENS=4096
